<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
        };

        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === "dark"
              ? true
              : mode === "light"
                ? false
                : !document.documentElement.classList.contains("dark"),
          );
        });
      })();
    </script>

    <script>
      (function () {
        try {
          const storedTheme = localStorage.getItem("themeVariant");
          if (storedTheme)
            document.documentElement.classList.add(`theme-${storedTheme}`);
        } catch (event) {
          console.error(
            "Could not apply theme variant from localStorage",
            event,
          );
        }
      })();
    </script>

    <meta charset="utf-8" />
    <meta http-equiv="Content-Language" content="en" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Basecoat</title>
    <meta
      name="description"
      content="A components library built with Tailwind CSS that works with any web stack."
    />
    <meta name="title" content="Basecoat" />
    <meta
      name="keywords"
      content="components,component library,component system,UI,UI kit,shadcn,shadcn/ui,Tailwind CSS,Tailwind,CSS,HTML,Jinja,Nunjucks,JS,JavaScript,vanilla JS,vanilla JavaScript"
    />

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/assets/apple-touch-icon.png"
    />

    <link rel="stylesheet" href="/assets/styles.css" />
    <link rel="stylesheet" href="/assets/custom.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/command.js?v=0.3.11" defer></script>
    <script src="/assets/js/dropdown-menu.js?v=0.3.11" defer></script>
    <script src="/assets/js/popover.js?v=0.3.11" defer></script>
    <script src="/assets/js/select.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11" defer></script>
    <script src="/assets/js/tabs.js?v=0.3.11" defer></script>
    <script src="/assets/js/toast.js?v=0.3.11" defer></script>

    <script src="https://unpkg.com/htmx.org@2.0.4"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/django.min.js"></script>
    <script>
      const highlight = () => {
        if (!window.hljs) return;
        document
          .querySelectorAll(
            "pre code:not([data-highlighted]), code.highlight:not([data-highlighted])",
          )
          .forEach((el) => hljs.highlightElement(el));
      };

      if (!window._hljsInit) {
        window._hljsInit = true;
        document.addEventListener("DOMContentLoaded", highlight);
        document.addEventListener("htmx:afterSwap", highlight);
      }
    </script>
    <script>
      document.addEventListener("htmx:historyRestore", () => {
        if (window.basecoat) window.basecoat.initAll();
      });
    </script>
  </head>
  <body
    class="bg-slate-50 antialiased min-h-screen text-slate-800"
  >
    <div class="min-h-screen flex flex-col md:flex-row bg-slate-50">
      <!-- Left Panel: Form & Logo -->
      <div class="w-full md:w-[45%] lg:w-[40%] flex flex-col justify-between p-8 md:p-12 lg:p-16 min-h-screen bg-white border-r border-slate-100 shadow-[20px_0_40px_rgba(6,47,36,0.01)]">
        <!-- Logo and Brand -->
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-600 rounded-xl flex items-center justify-center text-white shadow-md shadow-emerald-100 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
              <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="text-slate-900 font-black text-lg tracking-tight leading-none">Facultyware</span>
            <span class="text-slate-400 font-bold text-[9px] uppercase tracking-widest leading-none mt-1">Central Panel</span>
          </div>
        </div>

        <!-- Center content -->
        <div class="my-auto py-8 max-w-sm w-full mx-auto">
          <h1 class="text-3xl font-extrabold text-slate-900 mb-2 tracking-tight">Selamat Datang</h1>
          <p class="text-slate-500 text-sm font-medium mb-8">Masuk ke akun SIPL Anda untuk melanjutkan.</p>

          <!-- Error Alert -->
          <% if (error) { %>
            <div class="bg-rose-50 text-rose-600 text-sm p-4 rounded-xl border border-rose-100 text-center mb-6 font-semibold shadow-sm flex items-center justify-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 shrink-0">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
              <%= error %>
            </div>
          <% } %>

          <!-- Card Form -->
          <div class="bg-white rounded-3xl p-2 shadow-[0_20px_50px_rgba(6,47,36,0.03)] border border-slate-100">
            <form action="/login" method="POST" class="flex flex-col gap-5 p-6">
              <div class="flex flex-col gap-2">
                <label for="email" class="text-[10px] font-extrabold text-slate-400 tracking-widest uppercase">Email / Username</label>
                <input
                  type="email"
                  name="email"
                  id="email"
                  required
                  class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-emerald-500/10 focus:border-emerald-500 transition shadow-inner"
                  placeholder="admin"
                />
              </div>

              <div class="flex flex-col gap-2">
                <label for="password" class="text-[10px] font-extrabold text-slate-400 tracking-widest uppercase">Kata Sandi</label>
                <input
                  type="password"
                  name="password"
                  id="password"
                  required
                  class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-emerald-500/10 focus:border-emerald-500 transition shadow-inner"
                />
              </div>

              <button
                type="submit"
                class="w-full bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white font-extrabold text-xs py-4 rounded-xl shadow-lg shadow-emerald-600/10 hover:shadow-xl hover:shadow-emerald-600/20 transition-all duration-250 uppercase tracking-widest flex items-center justify-center gap-2 mt-2"
              >
                Masuk Sekarang &rarr;
              </button>
            </form>
          </div>
        </div>

        <!-- Footer -->
        <div class="text-center md:text-left text-slate-400 text-xs font-semibold mt-auto tracking-wider uppercase">
          &copy; Kelompok B6 PWEB
        </div>
      </div>

      <!-- Right Panel: Abstract Modern Dark Green Mesh Gradient -->
      <div class="hidden md:flex md:w-[55%] lg:w-[60%] relative min-h-screen items-center justify-start p-12 lg:p-20 bg-gradient-to-tr from-[#022C22] via-[#064E3B] to-[#0F172A] overflow-hidden">
        <!-- Abstract shapes / Glowing orbs in background -->
        <div class="absolute w-[500px] h-[500px] rounded-full bg-emerald-500/10 blur-[120px] -top-20 -right-20"></div>
        <div class="absolute w-[400px] h-[400px] rounded-full bg-teal-500/10 blur-[100px] -bottom-20 -left-20"></div>
        
        <!-- Content -->
        <div class="relative z-10 max-w-xl text-white">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 text-emerald-200 text-[10px] font-extrabold tracking-widest uppercase mb-6 backdrop-blur-sm border border-white/10">
            ✨ Next-Gen Overtime System
          </div>
          <h2 class="text-3xl lg:text-5xl font-black leading-tight mb-6 tracking-tight drop-shadow-sm bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-100 to-emerald-200">
            Kelola Lembur Jadi Lebih Efisien
          </h2>
          <p class="text-slate-300 text-sm lg:text-lg font-medium leading-relaxed drop-shadow-sm">
            Sistem Informasi Pengelolaan Lembur (SIPL) hadir untuk mempermudah proses pengajuan dan persetujuan lembur secara transparan, akuntabel, dan terstruktur.
          </p>
        </div>
      </div>
    </div>
    <div id="toaster" class="toaster"></div>
  </body>
</html>

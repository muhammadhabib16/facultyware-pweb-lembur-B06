  <!-- Core Javascripts -->
  <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
  <script src="/assets/js/toast.js?v=0.3.11" defer></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>

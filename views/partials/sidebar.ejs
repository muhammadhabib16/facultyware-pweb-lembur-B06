<style>
  .glass-sidebar {
    background-color: #062f24 !important;
    border-right: 1px solid #04241b !important;
    box-shadow: 4px 0 24px rgba(6, 47, 36, 0.15) !important;
    height: 100vh !important;
    position: sticky !important;
    top: 0 !important;
    align-self: flex-start !important;
    overflow-y: auto !important;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    color: #a7f3d0 !important;
    text-decoration: none;
  }
  .sidebar-link:hover {
    background-color: rgba(255, 255, 255, 0.08) !important;
    transform: translateX(4px);
    color: #ffffff !important;
  }
  .sidebar-link.active-link {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
    color: #ffffff !important;
    font-weight: 700 !important;
    box-shadow: 0 4px 14px rgba(16, 185, 129, 0.35) !important;
  }
  .sidebar-logo-icon {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: #ffffff;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-weight: 800;
    font-size: 0.875rem;
    box-shadow: 0 4px 10px rgba(16, 185, 129, 0.25);
  }
  .sidebar-section-title {
    padding: 1.25rem 0.75rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #34d399 !important;
  }
  .sidebar-user-card {
    background: rgba(255, 255, 255, 0.04) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 0.75rem !important;
    padding: 1rem !important;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05) !important;
  }
  .sidebar-role-badge {
    background: rgba(16, 185, 129, 0.15) !important;
    color: #34d399 !important;
    border: 1px solid rgba(16, 185, 129, 0.3) !important;
    font-size: 0.65rem !important;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem !important;
    border-radius: 9999px !important;
    width: fit-content !important;
    display: inline-block !important;
  }
  .sidebar-logout-btn-custom {
    background-color: rgba(239, 68, 68, 0.08) !important;
    border: 1px solid rgba(239, 68, 68, 0.25) !important;
    color: #f87171 !important;
    font-weight: 700 !important;
    font-size: 0.875rem !important;
    border-radius: 0.75rem !important;
    padding: 0.75rem !important;
    transition: all 0.2s ease-in-out !important;
  }
  .sidebar-logout-btn-custom:hover {
    background-color: #ef4444 !important;
    color: #ffffff !important;
    border-color: #ef4444 !important;
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25) !important;
  }
</style>
<script>
  (() => {
    const highlightActiveLink = () => {
      const path = window.location.pathname;
      document.querySelectorAll('.sidebar-link').forEach(link => {
        const href = link.getAttribute('href');
        let isActive = false;
        if (href === path) {
          isActive = true;
        } else if (href !== '/home') {
          // Prevent /pimpinan/penugasan from matching /pimpinan/penugasan/buat
          if (href === '/pimpinan/penugasan' && path.startsWith('/pimpinan/penugasan/buat')) {
            isActive = false;
          } else {
            isActive = path.startsWith(href);
          }
        }
        
        if (isActive) {
          link.classList.add('active-link');
        } else {
          link.classList.remove('active-link');
        }
      });
    };

    // Execute immediately on swap/load
    highlightActiveLink();

    // Register global event handlers only once
    if (!window.sidebarHighlightRegistered) {
      window.sidebarHighlightRegistered = true;
      document.addEventListener('DOMContentLoaded', highlightActiveLink);
      document.addEventListener('htmx:afterSwap', highlightActiveLink);
    }
  })();
</script>
<aside class="w-64 glass-sidebar min-h-screen flex flex-col justify-between z-10 sticky top-0">
  <div class="p-6">
    <div class="flex items-center gap-3 mb-8 pb-4 border-b border-white/10">
      <div class="sidebar-logo-icon">FW</div>
      <span class="font-bold text-xl tracking-tight text-white">Facultyware</span>
    </div>

    <div class="mb-8 sidebar-user-card text-sm flex flex-col gap-2.5">
      <span class="font-bold truncate text-white tracking-tight text-sm"><%= user %></span>
      <span class="sidebar-role-badge"><%= role %></span>
    </div>

    <nav class="flex flex-col gap-1" hx-boost="true">
      <a href="/home" class="sidebar-link">Dashboard</a>

      <% if (role === 'pegawai') { %>
        <div class="sidebar-section-title">Modul Pegawai</div>
        <a href="/pegawai/tugas" class="sidebar-link">Daftar Tugas Aktif</a>
        <a href="/pegawai/permohonan" class="sidebar-link">Ajukan Lembur Mandiri</a>
        <a href="/pegawai/riwayat" class="sidebar-link">Riwayat Lembur</a>
      <% } %>

      <% if (role === 'pimpinan') { %>
        <div class="sidebar-section-title">Modul Pimpinan</div>
        <a href="/pimpinan/penugasan/buat" class="sidebar-link">Buat Tugas Lembur</a>
        <a href="/pimpinan/penugasan" class="sidebar-link">Daftar Tugas Anda</a>
        <a href="/pimpinan/laporan" class="sidebar-link">Daftar Laporan</a>
      <% } %>

      <% if (role === 'admin') { %>
        <div class="sidebar-section-title">Modul Admin</div>
        <a href="/pimpinan/penugasan" class="sidebar-link">Daftar Tugas Anda</a>
        <a href="/admin/rekap" class="sidebar-link">Rekap Bulanan</a>
        <a href="/admin/pegawai" class="sidebar-link">Kelola Pegawai</a>
      <% } %>
    </nav>
  </div>

  <div class="p-6 border-t border-white/10">
    <button hx-post="/logout" hx-trigger="click" class="btn w-full cursor-pointer flex items-center justify-center gap-2 sidebar-logout-btn-custom">
      Keluar Aplikasi
    </button>
  </div>
</aside>
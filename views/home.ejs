<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware Central Panel</title>
    <link rel="stylesheet" href="/assets/styles.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground overflow-x-hidden">

    <%- include('partials/sidebar') %>

    <main class="flex-1 p-6 md:p-10 space-y-8 w-full flex flex-col" hx-boost="true">
      
      <div class="flex flex-col gap-1.5 border-b pb-6">
        <h1 class="text-3xl font-extrabold tracking-tight">
          Selamat Datang Kembali, <span class="text-primary font-black"> <%= user %>!</span>
        </h1>
        <p class="text-muted-foreground text-sm max-w-2xl leading-relaxed">
          Sistem Panel Utama Facultyware siap digunakan. Berikut adalah ringkasan status operasional pelaksanaan kerja lembur riil hari ini.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div data-slot="card" class="rounded-xl border bg-card text-card-foreground p-6 flex flex-col justify-between shadow-xs hover:shadow-md transition-all duration-300 relative overflow-hidden group hover:-translate-y-1">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/5 rounded-bl-full transition-transform duration-500 grouphover:scale-110"></div>
          <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider relative z-10">Total Anggota Tim</span>
          <div class="flex items-baseline gap-2 mt-4 relative z-10">
            <span class="text-4xl font-black tracking-tight text-primary font-mono"><%= stats.totalTim %></span>
            <span class="text-xs text-muted-foreground font-medium">Karyawan Aktif</span>
          </div>
        </div>

        <div data-slot="card" class="rounded-xl border bg-card text-card-foreground p-6 flex flex-col justify-between shadow-xs hover:shadow-md transition-all duration-300 relative overflow-hidden group hover:-translate-y-1">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-500/5 rounded-bl-full transition-transform duration-500 group-hover:scale-110"></div>
          <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider relative z-10">Butuh Review Laporan</span>
          <div class="flex items-baseline gap-2 mt-4 relative z-10">
            <span class="text-4xl font-black tracking-tight font-mono" style="<%= stats.pendingReview > 0 ? 'color: #f59e0b;' : 'color: var(--muted-foreground);' %>">
              <%= stats.pendingReview %>
            </span>
            <span class="text-xs text-muted-foreground font-medium">Berkas Menunggu</span>
          </div>
        </div>

        <div data-slot="card" class="rounded-xl border bg-card text-card-foreground p-6 flex flex-col justify-between shadow-xs hover:shadow-md transition-all duration-300 relative overflow-hidden group hover:-translate-y-1">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-500/5 rounded-bl-full transition-transform duration-500 group-hover:scale-110"></div>
          <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider relative z-10">Lembur Disetujui</span>
          <div class="flex items-baseline gap-2 mt-4 relative z-10">
            <span class="text-4xl font-black tracking-tight text-emerald-500 font-mono"><%= stats.totalDisetujui %></span>
            <span class="text-xs text-muted-foreground font-medium">Selesai Siklus</span>
          </div>
        </div>
      </div>

      <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 space-y-4">
        <div class="border-b pb-4">
          <h2 class="text-xl font-bold tracking-tight">Aktivitas Agenda Lembur Terbaru</h2>
          <p class="text-xs text-muted-foreground mt-1">Daftar permohonan dan penugasan lembur yang baru saja masuk ke dalam sistem database.</p>
        </div>

        <div class="relative w-full overflow-x-auto border rounded-lg bg-card">
          <table class="table w-full text-left border-collapse text-sm">
            <thead class="bg-muted/50 font-semibold text-muted-foreground border-b">
              <tr>
                <th class="p-4 text-xs uppercase tracking-wider">No. Permohonan</th>
                <th class="p-4 text-xs uppercase tracking-wider">Pegawai</th>
                <th class="p-4 text-xs uppercase tracking-wider">Agenda</th>
                <th class="p-4 text-xs uppercase tracking-wider text-center">Status</th>
                <th class="p-4 text-xs uppercase tracking-wider text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y bg-card/50">
              <% if (recentRequests && recentRequests.length > 0) { %>
                <% recentRequests.forEach(item => { %>
                  <tr class="hover:bg-muted/40 transition-colors duration-200">
                    <td class="p-4 font-mono text-xs font-bold text-primary"><%= item.request_number %></td>
                    <td class="p-4 font-semibold"><%= item.pegawai_name || 'Tidak Diketahui' %></td>
                    <td class="p-4 text-muted-foreground max-w-[240px] truncate"><%= item.title %></td>
                    <td class="p-4 text-center">
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold tracking-wide capitalize
                        <%= item.status === 'approved' ? 'bg-emerald-500/15 text-emerald-500' : 
                            item.status === 'completed' ? 'bg-amber-500/15 text-amber-500' : 
                            item.status === 'rejected' ? 'bg-destructive/15 text-destructive' : 
                            'bg-muted text-muted-foreground' %>">
                        <%= item.status %>
                      </span>
                    </td>
                    <td class="p-4 text-right">
                      <a href="/pimpinan/laporan/<%= item.id %>" class="btn btn-sm btn-outline cursor-pointer shadow-2xs font-medium">
                        Periksa
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="p-8 text-center text-muted-foreground font-medium">
                    Belum ada riwayat transaksi agenda kerja lembur yang tercatat di database, Bos.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 border-dashed bg-muted/20">
        <h2 class="text-sm font-bold mb-2 flex items-center gap-2">
          Catatan Penting Untuk Anggota Tim:
        </h2>
        <p class="text-xs text-muted-foreground leading-relaxed">
          Pastikan setiap pembuatan halaman modul fungsional baru ditaruh di dalam sub-folder <code class="bg-muted border px-1.5 py-0.5 rounded text-[11px] font-mono font-bold text-foreground">views/pegawai/</code> atau <code class="bg-muted border px-1.5 py-0.5 rounded text-[11px] font-mono font-bold text-foreground">views/admin/</code>. Jangan lupa untuk menyertakan partial eksternal <code class="bg-muted border px-1.5 py-0.5 rounded text-[11px] font-mono font-bold text-primary">&lt;%- include('../partials/sidebar') %&gt;</code> di baris layout paling atas agar kesatuan kendali navigasi dashboard kita tetap kokoh dan sinkron.
        </p>
      </div>
    </main>
  </body>
</html>
<!doctype html>
<html lang="en">

<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (
          stored
            ? stored === "dark"
            : matchMedia("(prefers-color-scheme: dark)").matches
        ) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) { }
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %> — Facultyware Central Panel
  </title>
  <link rel="stylesheet" href="/assets/styles.css" />
  <link rel="stylesheet" href="/assets/custom.css" />

  <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>

<body class="bg-background flex min-h-screen text-foreground overflow-x-hidden selection:bg-primary/20 selection:text-primary">

  <%- include('partials/sidebar') %>

    <main class="flex-1 p-5 md:p-8 space-y-6 max-w-6xl mx-auto w-full flex flex-col relative" hx-boost="true">
      
      <div class="absolute top-0 left-0 w-full h-80 bg-gradient-to-b from-primary/5 to-transparent pointer-events-none -z-10"></div>

      <div class="flex flex-col gap-2 border-b border-border/40 pb-6 relative">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 text-primary w-fit text-[11px] font-bold px-2.5 py-0.5 tracking-wide shadow-xs border border-primary/20">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          Sistem Online
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground leading-none">
          Selamat Datang Kembali, <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-primary/80 to-primary/60 font-extrabold"><%= user %>!</span>
        </h1>
        <p class="text-muted-foreground text-sm max-w-2xl leading-relaxed tracking-normal">
          Sistem Panel Utama Facultyware siap digunakan. Berikut adalah ringkasan status operasional pelaksanaan kerja lembur riil hari ini.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">

        <div data-slot="card" class="rounded-xl border border-border/50 bg-card/40 backdrop-blur-sm p-5 flex flex-col justify-between shadow-xs hover:shadow-sm hover:border-primary/30 transition-all duration-300 relative overflow-hidden group">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary/5 rounded-full blur-xl transition-transform duration-500 group-hover:scale-125"></div>
          <div class="flex justify-between items-start relative z-10 w-full">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Total Anggota Tim</span>
              <span class="text-3xl font-extrabold tracking-tight text-foreground leading-none mt-1"><%= stats.totalTim %></span>
            </div>
            <div class="p-2 bg-primary/10 rounded-lg text-primary border border-primary/10 shadow-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border/20 relative z-10 w-full">
            <span class="text-[11px] text-muted-foreground font-medium tracking-normal">Karyawan Aktif Terdaftar</span>
          </div>
        </div>

        <div data-slot="card" class="rounded-xl border border-border/50 bg-card/40 backdrop-blur-sm p-5 flex flex-col justify-between shadow-xs hover:shadow-sm hover:border-amber-500/30 transition-all duration-300 relative overflow-hidden group">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-500/5 rounded-full blur-xl transition-transform duration-500 group-hover:scale-125"></div>
          <div class="flex justify-between items-start relative z-10 w-full">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Butuh Review</span>
              <span class="text-3xl font-extrabold tracking-tight <%= stats.pendingReview > 0 ? 'text-amber-500' : 'text-foreground' %> leading-none mt-1"><%= stats.pendingReview %></span>
            </div>
            <div class="p-2 bg-amber-500/10 rounded-lg text-amber-500 border border-amber-500/10 shadow-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <circle cx="12" cy="14" r="3" />
                <line x1="12" y1="11" x2="12" y2="14" />
                <line x1="12" y1="14" x2="14.5" y2="15.5" />
              </svg>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border/20 relative z-10 w-full">
            <span class="text-[11px] text-muted-foreground font-medium tracking-normal">Berkas Menunggu Verifikasi</span>
          </div>
        </div>

        <div data-slot="card" class="rounded-xl border border-border/50 bg-card/40 backdrop-blur-sm p-5 flex flex-col justify-between shadow-xs hover:shadow-sm hover:border-emerald-500/30 transition-all duration-300 relative overflow-hidden group">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-500/5 rounded-full blur-xl transition-transform duration-500 group-hover:scale-125"></div>
          <div class="flex justify-between items-start relative z-10 w-full">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-widest">Disetujui</span>
              <span class="text-3xl font-extrabold tracking-tight text-emerald-500 leading-none mt-1"><%= stats.totalDisetujui %></span>
            </div>
            <div class="p-2 bg-emerald-500/10 rounded-lg text-emerald-500 border border-emerald-500/10 shadow-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
              </svg>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-border/20 relative z-10 w-full">
            <span class="text-[11px] text-muted-foreground font-medium tracking-normal">Selesai Siklus Alur Kerja</span>
          </div>
        </div>
      </div>

      <div data-slot="card" class="rounded-xl border border-border/50 bg-card shadow-xs flex flex-col overflow-hidden">
        <div class="p-5 border-b border-border/50 flex justify-between items-center bg-muted/5">
          <div class="space-y-0.5">
            <h2 class="text-base font-bold tracking-tight text-foreground">Aktivitas Agenda Lembur Terbaru</h2>
            <p class="text-xs text-muted-foreground">Daftar permohonan dan penugasan lembur yang baru saja masuk ke sistem.</p>
          </div>
          <div class="p-2 bg-primary/5 rounded-lg text-primary hidden md:block border border-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
            </svg>
          </div>
        </div>

        <div class="w-full overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead class="bg-muted/30 text-muted-foreground border-b border-border/30">
              <tr>
                <th class="p-3.5 text-[10px] uppercase tracking-widest font-bold">No. Permohonan</th>
                <th class="p-3.5 text-[10px] uppercase tracking-widest font-bold">Pegawai</th>
                <th class="p-3.5 text-[10px] uppercase tracking-widest font-bold">Agenda</th>
                <th class="p-3.5 text-[10px] uppercase tracking-widest font-bold text-center">Status</th>
                <th class="p-3.5 text-[10px] uppercase tracking-widest font-bold text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
              <% if (recentRequests && recentRequests.length > 0) { %>
                <% recentRequests.forEach(item => { %>
                  <tr class="hover:bg-muted/20 transition-colors duration-150 group">
                    <td class="p-3.5 font-mono text-xs font-bold text-primary tracking-tight">
                      <%= item.request_number %>
                    </td>
                    <td class="p-3.5 font-semibold text-foreground text-xs md:text-sm tracking-normal">
                      <%= item.pegawai_name || 'Tidak Diketahui' %>
                    </td>
                    <td class="p-3.5 text-muted-foreground text-xs max-w-[200px] truncate tracking-normal">
                      <%= item.title %>
                    </td>
                    <td class="p-3.5 text-center">
                      <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-[10px] font-bold tracking-wide capitalize border
                        <%= item.status === 'approved' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-emerald-500/10' : 
                            item.status === 'waiting_approval' ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/10' : 
                            item.status === 'rejected' ? 'bg-destructive/10 text-destructive border-destructive/10' : 
                            'bg-muted text-muted-foreground border-border' %>">
                        <span class="w-1.5 h-1.5 rounded-full 
                          <%= item.status === 'approved' ? 'bg-emerald-500' : 
                              item.status === 'waiting_approval' ? 'bg-amber-500' : 
                              item.status === 'rejected' ? 'bg-destructive' : 
                              'bg-muted-foreground' %>"></span>
                        <%= item.status.replace('_', ' ') %>
                      </span>
                    </td>
                    <td class="p-3.5 text-right">
                      <% if (role === 'pimpinan') { %>
                        <% if (['waiting_approval', 'approved', 'rejected'].includes(item.status)) { %>
                          <a href="/pimpinan/laporan/<%= item.id %>" class="inline-flex items-center text-[11px] bg-background border border-border hover:border-primary hover:text-primary hover:bg-primary/5 transition-all shadow-2xs font-bold px-3 py-1 rounded-md tracking-wide">
                            Periksa
                          </a>
                        <% } else { %>
                          <button disabled class="inline-flex items-center text-[11px] bg-muted text-muted-foreground border border-border opacity-50 cursor-not-allowed font-bold px-3 py-1 rounded-md tracking-wide">
                            Periksa
                          </button>
                        <% } %>
                      <% } else { %>
                        <span class="text-xs text-muted-foreground italic opacity-40 select-none">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="p-10 text-center">
                    <div class="flex flex-col items-center justify-center gap-2 text-muted-foreground">
                      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-20">
                        <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
                        <line x1="16" x2="16" y1="2" y2="6" />
                        <line x1="8" x2="8" y1="2" y2="6" />
                        <line x1="3" x2="21" y1="10" y2="10" />
                        <path d="m9 16 2 2 4-4" />
                      </svg>
                      <span class="font-medium text-xs tracking-normal opacity-80">Belum ada riwayat transaksi agenda kerja lembur yang tercatat.</span>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      
    </main>
</body>

</html>
<!doctype html>
<html lang="en">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) { }
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — Facultyware</title>
  <link rel="stylesheet" href="/assets/styles.css" />
  <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>

<body class="bg-background flex min-h-screen text-foreground overflow-x-hidden">
  <%- include('../partials/sidebar') %>
  
  <main class="flex-1 p-4 md:p-6 space-y-5 max-w-4xl mx-auto w-full" hx-boost="true">
    <div class="w-full">

      <div class="mb-6">
        <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
        <p class="text-sm text-muted-foreground">Daftarkan data pegawai baru sekaligus buat akun login aplikasi mereka.</p>
      </div>

      <div id="form-container" class="card p-6 bg-card border rounded-lg shadow-sm">
        <% if (error) { %>
          <div class="bg-destructive/15 text-destructive text-sm p-3 rounded-md border border-destructive/20 text-center mb-4">
            <%= error %>
          </div>
        <% } %>

        <form hx-post="/admin/pegawai/tambah" hx-target="#form-container" hx-swap="innerHTML" class="space-y-6">
          
          <!-- 1. DATA PRIBADI -->
          <div>
            <h2 class="text-md font-bold border-b pb-2 mb-4 text-primary">1. Informasi Pribadi Pegawai</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="name">Nama Lengkap *</label>
                <input type="text" name="name" id="name" class="input w-full" placeholder="Nama lengkap pegawai" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="employee_number">Nomor Induk Pegawai (NIP) *</label>
                <input type="text" name="employee_number" id="employee_number" class="input w-full" placeholder="Contoh: NIP-19900101-002" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="national_id_number">NIK (No. KTP)</label>
                <input type="text" name="national_id_number" id="national_id_number" class="input w-full" placeholder="Masukkan 16 digit NIK" />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="tax_id_number">NPWP (No. Pokok Wajib Pajak)</label>
                <input type="text" name="tax_id_number" id="tax_id_number" class="input w-full" placeholder="Masukkan Nomor NPWP" />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="birth_place">Tempat Lahir *</label>
                <input type="text" name="birth_place" id="birth_place" class="input w-full" placeholder="Contoh: Padang" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="birth_date">Tanggal Lahir *</label>
                <input type="date" name="birth_date" id="birth_date" class="input w-full" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="gender">Jenis Kelamin *</label>
                <select name="gender" id="gender" class="select w-full" required>
                  <option value="">-- Pilih Jenis Kelamin --</option>
                  <option value="male">Laki-laki</option>
                  <option value="female">Perempuan</option>
                </select>
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="religion">Agama</label>
                <input type="text" name="religion" id="religion" class="input w-full" placeholder="Contoh: Islam, Kristen, dll." />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="marital_status">Status Pernikahan *</label>
                <select name="marital_status" id="marital_status" class="select w-full" required>
                  <option value="">-- Pilih Status Pernikahan --</option>
                  <option value="single">Single (Belum Menikah)</option>
                  <option value="married">Married (Menikah)</option>
                  <option value="divorced">Divorced (Cerai)</option>
                </select>
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="phone_number">No. Telepon/WhatsApp</label>
                <input type="text" name="phone_number" id="phone_number" class="input w-full" placeholder="Contoh: 081234567890" />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full md:col-span-2">
                <label class="text-sm font-medium leading-none" for="address">Alamat Tempat Tinggal *</label>
                <textarea name="address" id="address" class="input w-full min-h-[60px] py-2" placeholder="Masukkan alamat lengkap domisili pegawai saat ini" required></textarea>
              </div>

            </div>
          </div>

          <!-- 2. DATA PEKERJAAN -->
          <div>
            <h2 class="text-md font-bold border-b pb-2 mb-4 text-primary">2. Data Penugasan Kerja & Instansi</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="organization_unit_id">Divisi / Unit Kerja *</label>
                <select name="organization_unit_id" id="organization_unit_id" class="select w-full" required>
                  <option value="">-- Pilih Divisi Kerja --</option>
                  <% divisi.forEach(div => { %>
                    <option value="<%= div.id %>"><%= div.name %></option>
                  <% }) %>
                </select>
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="employment_status_id">Status Pekerjaan *</label>
                <select name="employment_status_id" id="employment_status_id" class="select w-full" required>
                  <option value="">-- Pilih Status Pekerjaan --</option>
                  <% statusKerja.forEach(sk => { %>
                    <option value="<%= sk.id %>"><%= sk.name %></option>
                  <% }) %>
                </select>
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="hire_date">Tanggal Mulai Bekerja *</label>
                <input type="date" name="hire_date" id="hire_date" class="input w-full" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="status">Status Aktif *</label>
                <select name="status" id="status" class="select w-full" required>
                  <option value="active">Aktif (Dapat Mengambil Lembur)</option>
                  <option value="inactive">Nonaktif</option>
                </select>
              </div>

            </div>
          </div>

          <!-- 3. KREDENSIAL LOGIN -->
          <div>
            <h2 class="text-md font-bold border-b pb-2 mb-4 text-primary">3. Informasi Akun & Kredensial Login</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="email">Alamat Email *</label>
                <input type="email" name="email" id="email" class="input w-full" placeholder="email@facultyware.com" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="password">Kata Sandi Default *</label>
                <input type="password" name="password" id="password" class="input w-full" placeholder="Ketik Password baru" required />
              </div>

              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="role_id">Hak Akses / Peran *</label>
                <select name="role_id" id="role_id" class="select w-full" required>
                  <option value="">-- Pilih Peran User --</option>
                  <% roles.forEach(role => { %>
                    <option value="<%= role.id %>"><%= role.name %></option>
                  <% }) %>
                </select>
              </div>

            </div>
          </div>

          <div class="flex justify-end gap-3 pt-4 border-t">
            <a hx-get="/admin/pegawai" hx-target="body" hx-swap="outerHTML" class="btn btn-outline cursor-pointer">Batal</a>
            <button type="submit" class="btn btn-primary">Simpan Data Pegawai</button>
          </div>

        </form>
      </div>

    </div>
  </main>
</body>
</html>

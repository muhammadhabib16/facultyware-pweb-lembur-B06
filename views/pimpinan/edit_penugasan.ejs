<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground">

    <%- include('../partials/sidebar') %>

    <main class="flex-1 p-8 md:p-10 space-y-6" hx-boost="true">
      <div class="max-w-2xl mx-auto">
        
        <div class="mb-6 flex items-center gap-4">
          <a href="/pimpinan/penugasan" class="btn btn-sm btn-outline">← Batal</a>
          <div>
            <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
            <p class="text-sm text-muted-foreground">Mengubah parameter data perintah penugasan lembur nomor <span class="font-mono font-semibold text-primary"><%= tugas.request_number %></span>.</p>
          </div>
        </div>

        <div class="card p-6 bg-card border rounded-lg shadow-sm">
          <% if (error) { %>
            <div class="bg-destructive/15 text-destructive text-sm p-3 rounded-md border border-destructive/20 text-center mb-4">
              <%= error %>
            </div>
          <% } %>

          <form hx-post="/pimpinan/penugasan/<%= assignmentId = tugas.id %>/edit" class="space-y-4">
            
            <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
              <label class="text-sm font-medium leading-none" for="employee_id">Pegawai Pelaksana Tugas</label>
              <select name="employee_id" id="employee_id" class="select w-full" required>
                <% employees.forEach(emp => { %>
                  <option value="<%= emp.id %>" <%= tugas.submitted_by === emp.id ? 'selected' : '' %>>
                    <%= emp.name %> (<%= emp.employee_number %>)
                  </option>
                <% }) %>
              </select>
            </div>

            <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
              <label class="text-sm font-medium leading-none" for="title">Judul Agenda Lembur</label>
              <input type="text" name="title" id="title" class="input w-full" value="<%= tugas.title %>" required />
            </div>

            <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
              <label class="text-sm font-medium leading-none" for="description">Deskripsi Instruksi / Catatan</label>
              <textarea name="description" id="description" class="input w-full min-h-[100px] py-2"><%= tugas.description %></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="request_date">Tanggal</label>
                <input type="date" name="request_date" id="request_date" class="input w-full" value="<%= new Date(tugas.request_date).toISOString().split('T')[0] %>" required />
              </div>
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="planned_start_time">Jam Mulai</label>
                <input type="datetime-local" name="planned_start_time" id="planned_start_time" class="input w-full" value="<%= new Date(tugas.planned_start_time).toISOString().slice(0,16) %>" required />
              </div>
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="planned_end_time">Jam Selesai</label>
                <input type="datetime-local" name="planned_end_time" id="planned_end_time" class="input w-full" value="<%= new Date(tugas.planned_end_time).toISOString().slice(0,16) %>" required />
              </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t">
              <a href="/pimpinan/penugasan" class="btn btn-outline">Batal</a>
              <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
            </div>

          </form>
        </div>

      </div>
    </main>
  </body>
</html>
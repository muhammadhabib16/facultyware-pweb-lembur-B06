<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground">

    <%- include('../partials/sidebar') %>

    <main class="flex-1 p-4 md:p-6 space-y-5 max-w-6xl mx-auto w-full" hx-boost="true">
      <div>
        <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
        <p class="text-sm text-muted-foreground">Memantau seluruh daftar instruksi tugas kerja lembur yang telah diterbitkan untuk pegawai.</p>
      </div>

      <div class="card p-4 bg-background border rounded-lg shadow-sm">
        <form hx-get="/pimpinan/penugasan" hx-target="body" hx-swap="outerHTML" hx-push-url="true" class="flex gap-4">
          <input 
            type="text" 
            name="search" 
            placeholder="Cari nomor tugas, judul, atau nama pegawai..." 
            value="<%= filters.search || '' %>"
            class="input flex-1"
          />
          <button type="submit" class="btn btn-primary">Cari</button>
        </form>
      </div>

      <div class="card overflow-hidden border rounded-lg shadow-sm bg-background">
        <div class="overflow-x-auto">
          <table class="table w-full text-left border-collapse text-sm">
            <thead class="bg-muted/50 font-medium text-muted-foreground">
              <tr class="border-b">
                <th class="p-4">No. Penugasan</th>
                <th class="p-4">Pegawai Ditugaskan</th>
                <th class="p-4">Agenda Kerja</th>
                <th class="p-4">Tgl Pelaksanaan</th>
                <th class="p-4 text-center">Status</th>
                <th class="p-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <% if (penugasan && penugasan.length > 0) { %>
                <% penugasan.forEach(item => { %>
                  <tr class="hover:bg-muted/30 transition-colors">
                    <td class="p-4 font-mono text-xs font-semibold text-primary"><%= item.request_number %></td>
                    <td class="p-4">
                      <div class="font-medium"><%= item.pegawai_name %></div>
                      <div class="text-xs text-muted-foreground"><%= item.unit_name %></div>
                    </td>
                    <td class="p-4 max-w-[200px] truncate"><%= item.title %></td>
                    <td class="p-4 text-xs">
                      <%= new Date(item.request_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="p-4 text-center">
                      <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize
                        <%= item.status === 'assigned' ? 'bg-blue-500/15 text-blue-600' :
                            item.status === 'waiting_approval' ? 'bg-amber-500/15 text-amber-600' :
                            item.status === 'approved' ? 'bg-emerald-500/15 text-emerald-600' :
                            item.status === 'rejected' ? 'bg-destructive/15 text-destructive' :
                            'bg-slate-500/15 text-slate-600' %>">
                        <span class="w-1.5 h-1.5 rounded-full
                          <%= item.status === 'assigned' ? 'bg-blue-500' :
                              item.status === 'waiting_approval' ? 'bg-amber-500 animate-pulse' :
                              item.status === 'approved' ? 'bg-emerald-500' :
                              item.status === 'rejected' ? 'bg-destructive' :
                              'bg-slate-500' %>"></span>
                        <%= item.status === 'waiting_approval' ? 'Waiting Approval' : item.status %>
                      </span>
                    </td>
<td class="p-4 text-right flex justify-end gap-2">
                      <a href="/pimpinan/penugasan/<%= item.id %>" class="btn btn-sm btn-outline cursor-pointer">Lihat Detail</a>
                      
                      <% if (item.status === 'assigned' || item.status === 'pending') { %>
                        <a href="/pimpinan/penugasan/<%= item.id %>/edit" class="btn btn-sm btn-secondary text-xs">Ubah</a>
                        
                        <button 
                          hx-delete="/pimpinan/penugasan/<%= item.id %>" 
                          hx-confirm="Apakah Anda yakin ingin membatalkan/menghapus penugasan <%= item.request_number %> ini secara permanen?" 
                          hx-target="closest tr" 
                          hx-swap="outerHTML"
                          class="btn btn-sm border-destructive text-destructive hover:bg-destructive hover:text-destructive-foreground btn-outline text-xs">
                          Hapus
                        </button>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="p-8 text-center text-muted-foreground">
                    Belum ada riwayat penugasan resmi yang diterbitkan.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </body>
</html>
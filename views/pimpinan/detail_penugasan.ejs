<!doctype html>
<html lang="en">

<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) { }
    })();
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — Facultyware</title>
  <link rel="stylesheet" href="/assets/styles.css" />
  <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>

<body class="bg-background flex min-h-screen text-foreground overflow-x-hidden">

  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-4 md:p-6 space-y-5 max-w-6xl mx-auto w-full" hx-boost="true">

    <%
      // Tentukan kelas badge status sekali di sini, bukan inline di atribut HTML
      var badgeClass = '';
      var dotClass = '';
      var statusLabel = tugas.status;
      if (tugas.status === 'assigned') {
        badgeClass = 'bg-blue-500/15 text-blue-600 dark:text-blue-400';
        dotClass = 'bg-blue-500';
        statusLabel = 'Assigned';
      } else if (tugas.status === 'waiting_approval') {
        badgeClass = 'bg-amber-500/15 text-amber-600 dark:text-amber-400';
        dotClass = 'bg-amber-500 animate-pulse';
        statusLabel = 'Waiting Approval';
      } else if (tugas.status === 'approved') {
        badgeClass = 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400';
        dotClass = 'bg-emerald-500';
        statusLabel = 'Approved';
      } else if (tugas.status === 'rejected') {
        badgeClass = 'bg-destructive/15 text-destructive';
        dotClass = 'bg-destructive';
        statusLabel = 'Rejected';
      } else {
        badgeClass = 'bg-muted text-muted-foreground';
        dotClass = 'bg-muted-foreground';
      }
    %>

    <%# Header: Tombol kembali + Judul + Aksi %>
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-3">
        <a href="/pimpinan/penugasan" class="btn btn-sm btn-outline cursor-pointer">← Kembali</a>
        <div>
          <h1 class="text-xl font-bold tracking-tight"><%= tugas.request_number %></h1>
          <p class="text-xs text-muted-foreground">Rincian lembar perintah kerja lembur internal.</p>
        </div>
      </div>

      <%# Tombol aksi berdasarkan status %>
      <div class="flex flex-wrap items-center gap-2">
        <a href="/pimpinan/penugasan/<%= tugas.id %>/ekspor/pdf" hx-boost="false" target="_blank"
          class="btn btn-sm btn-outline inline-flex items-center gap-1.5 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Ekspor ke PDF
        </a>

        <% if (tugas.status === 'waiting_approval' || tugas.status === 'pending') { %>
          <button onclick="openRejectModal()"
            class="btn btn-sm btn-outline border-destructive text-destructive hover:bg-destructive/10 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
              <circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
            </svg>
            <%= tugas.status === 'pending' ? 'Tolak Permohonan' : 'Tolak / Minta Revisi' %>
          </button>
          <button
            hx-post="/pimpinan/penugasan/<%= tugas.id %>/approve"
            hx-confirm="<%= tugas.status === 'pending' ? 'Apakah Anda yakin ingin menyetujui permohonan lembur mandiri ini?' : 'Apakah Anda yakin ingin menyetujui laporan realisasi kerja lembur ini?' %>"
            class="btn btn-sm btn-primary cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <%= tugas.status === 'pending' ? 'Setujui Permohonan' : 'Konfirmasi Setuju' %>
          </button>
        <% } %>

        <% if (tugas.status === 'assigned' || tugas.status === 'pending') { %>
          <button
            hx-delete="/pimpinan/penugasan/<%= tugas.id %>"
            hx-confirm="Yakin ingin membatalkan dan menghapus penugasan ini?"
            hx-push-url="/pimpinan/penugasan"
            class="btn btn-sm btn-outline border-destructive text-destructive hover:bg-destructive/10 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
              <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
              <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
            </svg>
            Hapus
          </button>
          <a href="/pimpinan/penugasan/<%= tugas.id %>/edit" class="btn btn-sm btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
            </svg>
            Ubah Penugasan
          </a>
        <% } %>
      </div>
    </div>

    <%# Banner status %>
    <% if (tugas.status === 'waiting_approval') { %>
      <div class="flex items-center gap-3 p-4 rounded-xl border border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <div>
          <p class="font-semibold text-sm">Laporan realisasi kerja menunggu persetujuan Anda.</p>
          <p class="text-xs mt-0.5 opacity-80">Periksa data di bawah, lalu gunakan tombol <strong>Konfirmasi Setuju</strong> atau <strong>Tolak / Minta Revisi</strong>.</p>
        </div>
      </div>
    <% } else if (tugas.status === 'approved') { %>
      <div class="flex items-center gap-3 p-4 rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        <div>
          <p class="font-semibold text-sm">Penugasan ini telah disetujui.</p>
          <p class="text-xs mt-0.5 opacity-80">Laporan realisasi kerja sudah dikonfirmasi oleh pimpinan.</p>
        </div>
      </div>
    <% } else if (tugas.status === 'rejected') { %>
      <div class="flex items-center gap-3 p-4 rounded-xl border border-destructive/30 bg-destructive/10 text-destructive">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
        </svg>
        <div>
          <p class="font-semibold text-sm">Penugasan ini ditolak / diminta revisi.</p>
          <p class="text-xs mt-0.5 opacity-80">Laporan realisasi dikembalikan kepada pegawai untuk diperbaiki.</p>
        </div>
      </div>
    <% } else if (tugas.status === 'pending') { %>
      <div class="flex items-center gap-3 p-4 rounded-xl border border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <div>
          <p class="font-semibold text-sm">Permohonan lembur mandiri ini menunggu izin Anda.</p>
          <p class="text-xs mt-0.5 opacity-80">Gunakan tombol <strong>Setujui Permohonan</strong> untuk memberikan izin lembur, atau <strong>Tolak Permohonan</strong> jika tidak diperbolehkan.</p>
        </div>
      </div>
    <% } else if (tugas.status === 'assigned') { %>
      <div class="flex items-center gap-3 p-4 rounded-xl border border-blue-500/30 bg-blue-500/10 text-blue-700 dark:text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        <div>
          <p class="font-semibold text-sm">Penugasan sudah diterbitkan, menunggu laporan dari pegawai.</p>
          <p class="text-xs mt-0.5 opacity-80">Setelah pegawai mengisi laporan, status akan berubah ke <strong>Waiting Approval</strong>.</p>
        </div>
      </div>
    <% } %>

    <%# Konten: Detail + Info Pegawai %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <%# Kolom kiri: Detail agenda %>
      <div data-slot="card" class="rounded-xl border bg-card p-6 md:col-span-2 space-y-4">
        <div>
          <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Judul Agenda Kerja</h3>
          <p class="text-lg font-bold mt-1 text-foreground"><%= tugas.title %></p>
        </div>
        <hr class="border-border/50" />
        <div>
          <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Instruksi / Catatan Pimpinan</h3>
          <p class="text-sm text-muted-foreground leading-relaxed mt-1 bg-muted/40 p-4 rounded-lg border border-dashed">
            <%= tugas.description || 'Tidak ada deskripsi tambahan.' %>
          </p>
        </div>
      </div>

      <%# Kolom kanan: Status & Pelaksana %>
      <div data-slot="card" class="rounded-xl border bg-card p-6 space-y-4 text-sm">
        <h2 class="font-bold border-b border-border/50 pb-2">Status &amp; Pelaksana</h2>

        <div>
          <span class="text-muted-foreground block text-xs">Status Saat Ini:</span>
          <span class="inline-flex items-center gap-1.5 mt-1 rounded-full px-3 py-1 text-xs font-bold <%= badgeClass %>">
            <span class="w-1.5 h-1.5 rounded-full <%= dotClass %>"></span>
            <%= statusLabel %>
          </span>
        </div>

        <div>
          <span class="text-muted-foreground block text-xs">Pegawai Pelaksana:</span>
          <span class="font-semibold block mt-0.5"><%= tugas.pegawai_name || '-' %></span>
          <span class="text-xs text-muted-foreground font-mono"><%= tugas.pegawai_nip || '-' %> — <%= tugas.unit_name || '-' %></span>
        </div>

        <div>
          <span class="text-muted-foreground block text-xs">Tanggal Pelaksanaan:</span>
          <span class="font-semibold">
            <%= new Date(tugas.request_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
          </span>
        </div>

        <div>
          <span class="text-muted-foreground block text-xs">Rencana Jam Kerja:</span>
          <span class="font-semibold text-xs block font-mono text-primary">
            <%= new Date(tugas.planned_start_time).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
            s/d
            <%= new Date(tugas.planned_end_time).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %>
            WIB
          </span>
        </div>

        <div>
          <span class="text-muted-foreground block text-xs">Diterbitkan Oleh:</span>
          <span class="font-medium text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full inline-block mt-0.5">
            <%= tugas.pembuat_nama || 'Pimpinan' %>
          </span>
        </div>
      </div>
    </div>
  </main>

  <%# Modal: Form Penolakan / Revisi %>
  <div id="rejectModal"
    style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; z-index: 9999; padding: 16px; transition: opacity 300ms cubic-bezier(0.4, 0, 0.2, 1); opacity: 0;">
    <div class="bg-card border border-border/80 rounded-xl shadow-2xl w-full max-w-md overflow-hidden flex flex-col"
      style="transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1); transform: scale(0.95); background-color: var(--card-bg, #ffffff); border-radius: 12px; border: 1px solid rgba(4, 120, 87, 0.15);">
      
      <%# Modal Header %>
      <div class="flex justify-between items-center bg-muted/10" style="padding: 20px 24px; border-bottom: 1px solid rgba(4, 120, 87, 0.15);">
        <h3 class="text-sm md:text-base font-bold tracking-tight text-foreground leading-none">
          <%= tugas.status === 'pending' ? 'Tolak Permohonan Lembur' : 'Tolak / Minta Revisi Laporan' %>
        </h3>
        <button type="button" onclick="closeRejectModal()"
          class="rounded-lg p-2 text-muted-foreground hover:bg-muted hover:text-foreground transition-all cursor-pointer focus:outline-hidden"
          aria-label="Tutup">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
      
      <%# Modal Form %>
      <form hx-post="/pimpinan/penugasan/<%= tugas.id %>/reject" class="flex flex-col m-0" style="padding: 24px; gap: 24px;">
        
        <%# Kotak Notifikasi %>
        <div class="bg-destructive/5 text-destructive border border-destructive/10 rounded-lg" style="padding: 16px;">
          <div class="flex gap-3 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span class="tracking-normal font-medium text-xs leading-relaxed">
              <%= tugas.status === 'pending' ? 'Mohon berikan alasan penolakan agar rencana lembur ini dibatalkan.' : 'Berikan catatan perbaikan yang jelas agar pegawai dapat merevisi dan melengkapi laporannya.' %>
            </span>
          </div>
        </div>

        <%# Ruang Input Teks %>
        <div class="flex flex-col" style="gap: 8px;">
          <label for="catatan_revisi" class="block text-[10px] md:text-xs font-bold text-muted-foreground uppercase tracking-wider">
            Catatan Alasan / Perbaikan <span class="text-destructive font-bold">*</span>
          </label>
          <textarea id="catatan_revisi" name="catatan_revisi" rows="4" 
            class="w-full text-sm rounded-lg border border-border/80 bg-background text-foreground focus:border-primary focus:ring-primary focus:ring-1 transition-all placeholder:text-muted-foreground/50 focus:outline-hidden leading-relaxed"
            style="padding: 12px 16px; min-height: 110px;"
            placeholder="Contoh: Jam pelaksanaan aktual tidak sesuai dengan rencana agenda, mohon diperbaiki..."
            required></textarea>
        </div>

        <%# Modal Footer %>
        <div class="flex justify-end items-center gap-3" style="padding-top: 20px; border-top: 1px solid rgba(4, 120, 87, 0.15);">
          <button type="button"
            onclick="closeRejectModal()"
            class="btn btn-sm btn-outline cursor-pointer px-5 py-2 font-semibold shadow-2xs transition-colors rounded-lg text-xs md:text-sm">
            Batal
          </button>
          <button type="submit" class="btn btn-sm btn-destructive cursor-pointer px-5 py-2 font-semibold shadow-xs rounded-lg text-xs md:text-sm">
            Kirim Penolakan
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openRejectModal() {
      const modal = document.getElementById('rejectModal');
      const modalContent = modal.querySelector('.bg-card');
      
      modal.style.display = 'flex';
      
      // Force reflow to trigger CSS transitions
      void modal.offsetHeight;
      
      modal.style.opacity = '1';
      modalContent.style.transform = 'scale(1)';
    }

    function closeRejectModal() {
      const modal = document.getElementById('rejectModal');
      const modalContent = modal.querySelector('.bg-card');
      
      modal.style.opacity = '0';
      modalContent.style.transform = 'scale(0.95)';
      
      // Hide from layout once transition ends (300ms)
      setTimeout(() => {
        modal.style.display = 'none';
      }, 300);
    }
  </script>
</body>

</html>
<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground overflow-x-hidden">
    <%- include('../partials/sidebar') %>
    <main class="flex-1 p-8 md:p-10 space-y-6" hx-boost="true">
      <div class="max-w-2xl mx-auto">
        
        <div class="mb-6">
          <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
          <p class="text-sm text-muted-foreground">Ajukan rencana pelaksanaan kerja lembur mandiri untuk diverifikasi oleh Pimpinan.</p>
        </div>

        <div id="form-container" class="card p-6 bg-card border rounded-lg shadow-sm">
          
          <% if (error) { %>
            <div class="bg-destructive/15 text-destructive text-sm p-3 rounded-md border border-destructive/20 text-center mb-4">
              <%= error %>
            </div>
          <% } %>

          <form hx-post="/pegawai/permohonan" hx-target="#form-container" hx-swap="innerHTML" class="space-y-4">
            
            <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
              <label class="text-sm font-medium leading-none" for="title">Judul Agenda Lembur</label>
              <input type="text" name="title" id="title" class="input w-full" placeholder="Contoh: Migrasi Database Server Facultyware" required />
            </div>

            <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
              <label class="text-sm font-medium leading-none" for="description">Deskripsi Rencana Kegiatan</label>
              <textarea name="description" id="description" class="input w-full min-h-[80px] py-2" placeholder="Tuliskan detail pekerjaan atau alasan lembur Anda..."></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="request_date">Tanggal Pelaksanaan</label>
                <input type="date" name="request_date" id="request_date" class="input w-full" required />
              </div>
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="planned_start_time">Jam Mulai</label>
                <input type="datetime-local" name="planned_start_time" id="planned_start_time" class="input w-full" required />
              </div>
              <div role="group" data-slot="field" class="flex flex-col gap-1 w-full">
                <label class="text-sm font-medium leading-none" for="planned_end_time">Jam Selesai</label>
                <input type="datetime-local" name="planned_end_time" id="planned_end_time" class="input w-full" required />
              </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t">
              <a href="/home" class="btn btn-outline cursor-pointer">Batal</a>
              <button type="submit" class="btn btn-primary">Ajukan Permohonan</button>
            </div>

          </form>
        </div>

      </div>
    </main>

    <script>
      // Sinkronisasi dinamis tanggal pelaksanaan dengan waktu rencana mulai/selesai
      const reqDateInput = document.getElementById('request_date');
      const startTimeInput = document.getElementById('planned_start_time');
      const endTimeInput = document.getElementById('planned_end_time');

      reqDateInput.addEventListener('change', (e) => {
        const val = e.target.value;
        if (val) {
          if (!startTimeInput.value.startsWith(val)) {
            startTimeInput.value = `${val}T17:00`;
          }
          if (!endTimeInput.value.startsWith(val)) {
            endTimeInput.value = `${val}T20:00`;
          }
        }
      });
    </script>
  </body>
</html>

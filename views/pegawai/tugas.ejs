<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground">

    <%- include('../partials/sidebar') %>

    <main class="flex-1 p-4 md:p-6 space-y-5 max-w-6xl mx-auto w-full" hx-boost="true">
      <div>
        <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
        <p class="text-sm text-muted-foreground">Daftar instruksi tugas lembur dari pimpinan atau pengajuan mandiri yang belum dilaporkan.</p>
      </div>

      <div class="card p-4 bg-background border rounded-lg shadow-sm flex flex-col sm:flex-row gap-4 items-center justify-between">
        <form hx-get="/pegawai/tugas" hx-target="body" hx-swap="outerHTML" hx-push-url="true" class="flex gap-4 w-full sm:w-auto flex-1">
          <input 
            type="text" 
            name="keyword" 
            placeholder="Cari judul tugas atau nomor permintaan..." 
            value="<%= filters.keyword || '' %>"
            class="input flex-1 max-w-md"
          />
          <button type="submit" class="btn btn-primary">Cari</button>
        </form>
        <div class="flex gap-2 w-full sm:w-auto">
          <a
  href="/pegawai/tugas/export/pdf?keyword=<%= filters.keyword || '' %>"
  hx-boost="false"
  class="btn btn-outline flex items-center gap-1.5 cursor-pointer"
>
  Export PDF
</a>
        </div>
      </div>

      <div class="card overflow-hidden border rounded-lg shadow-sm bg-background">
        <div class="overflow-x-auto">
          <table class="table w-full text-left border-collapse text-sm">
            <thead class="bg-muted/50 font-medium text-muted-foreground">
              <tr class="border-b">
              <th class="p-4">Nomor Permintaan</th>
              <th class="p-4">Agenda Lembur</th>
              <th class="p-4 text-center">Status</th>
              <th class="p-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <% if (tugas && tugas.length > 0) { %>
                <% tugas.forEach(item => { %>
            <tr class="hover:bg-muted/30 transition-colors">
              <td class="p-4 font-mono text-xs font-semibold text-primary">
                <%= item.request_number %>
              </td>

              <td class="p-4">
                <div class="font-medium">
                  <%= item.title %>
                </div>
              </td>
              <td class="p-4 text-center">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize border
                  <%= item.status === 'pending' ? 'bg-amber-500/10 text-amber-600 border-amber-500/20' : '' %>
                  <%= item.status === 'approved' ? 'bg-blue-500/10 text-blue-600 border-blue-500/20' : '' %>
                  <%= item.status === 'rejected' ? 'bg-rose-500/10 text-rose-600 border-rose-500/20' : '' %>
                  <%= item.status === 'completed' ? 'bg-emerald-500/10 text-emerald-600 border-emerald-500/20' : '' %>
                ">
                  <%= item.status %>
                </span>
              </td>
              <td class="p-4 text-right">
                <a
                  href="/pegawai/tugas/<%= item.id %>"
                  class="btn btn-sm btn-outline"
                >
                  Detail
                </a>
              </td>
            </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="3" class="p-8 text-center text-muted-foreground">
                    Tidak ada tugas lembur aktif saat ini.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </body>
</html>

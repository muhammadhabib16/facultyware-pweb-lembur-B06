<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/assets/styles.css">
</head>

<body class="bg-background flex min-h-screen">

  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">

    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold">Riwayat Lembur</h1>
        <p class="text-muted-foreground">
          Daftar pengajuan lembur yang pernah dibuat.
        </p>
      </div>

      <a
        href="/pegawai/export/pdf"
        class="btn btn-primary"
      >
        Export PDF
      </a>
    </div>

    <div class="card p-6">

      <table class="w-full">

        <thead>
          <tr class="border-b">
            <th class="text-left py-3">No</th>
            <th class="text-left py-3">Nomor Request</th>
            <th class="text-left py-3">Agenda Lembur</th>
            <th class="text-left py-3">Status</th>
            <th class="text-left py-3">Aksi</th>
          </tr>
        </thead>

        <tbody>

          <% if (!riwayat || riwayat.length === 0) { %>

            <tr>
              <td colspan="5" class="py-6 text-center text-muted-foreground">
                Belum ada riwayat lembur.
              </td>
            </tr>

          <% } else { %>

            <% riwayat.forEach((item, index) => { %>

              <tr class="border-b">

                <td class="py-3">
                  <%= index + 1 %>
                </td>

                <td class="py-3 font-mono text-sm">
                  <%= item.request_number %>
                </td>

                <td class="py-3">
                  <%= item.title %>
                </td>

                <td class="py-3">

                  <% if (item.status === 'pending') { %>

                    <span class="px-2 py-1 rounded bg-yellow-500 text-black text-sm">
                      Pending
                    </span>

                  <% } else if (item.status === 'approved') { %>

                    <span class="px-2 py-1 rounded bg-blue-600 text-white text-sm">
                      Approved
                    </span>

                  <% } else if (item.status === 'completed') { %>

                    <span class="px-2 py-1 rounded bg-green-600 text-white text-sm">
                      Completed
                    </span>

                  <% } else if (item.status === 'waiting_approval') { %>

                    <span class="px-2 py-1 rounded bg-orange-500 text-black text-sm">
                      Waiting Approval
                    </span>

                  <% } else if (item.status === 'cancelled') { %>

                    <span class="px-2 py-1 rounded bg-red-600 text-white text-sm">
                      Cancelled
                    </span>

                  <% } else if (item.status === 'rejected') { %>

                    <span class="px-2 py-1 rounded bg-red-700 text-white text-sm">
                      Rejected
                    </span>

                  <% } else { %>

                    <span class="px-2 py-1 rounded bg-gray-600 text-white text-sm">
                      <%= item.status || '-' %>
                    </span>

                  <% } %>

                </td>

                <td class="py-3">

                  <% if (item.status === 'pending') { %>

                    <form
                      action="/pegawai/permohonan/<%= item.id %>/batal"
                      method="POST"
                      onsubmit="return confirm('Yakin ingin membatalkan pengajuan ini?')"
                    >
                      <button
                        type="submit"
                        class="btn btn-sm btn-outline"
                      >
                        Batalkan
                      </button>
                    </form>

                  <% } else if (item.status === 'completed') { %>

                    <a
                      href="/pegawai/laporan/<%= item.id %>"
                      class="btn btn-sm btn-primary"
                    >
                      Isi Laporan
                    </a>

                  <% } else if (item.status === 'waiting_approval') { %>

                    <button
                      type="button"
                      class="btn btn-sm btn-outline"
                    >
                      Detail
                    </button>

                  <% } else { %>

                    <span>-</span>

                  <% } %>

                </td>

              </tr>

            <% }) %>

          <% } %>

        </tbody>

      </table>

    </div>

  </main>

</body>

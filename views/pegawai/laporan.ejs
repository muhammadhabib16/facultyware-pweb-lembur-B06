<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/assets/styles.css">
</head>

<body class="bg-background text-foreground flex min-h-screen">

  <%- include('../partials/sidebar') %>

  <main class="flex-1 p-8">

    <div class="mb-6">
      <h1 class="text-3xl font-bold">
        Laporan Pelaksanaan Lembur
      </h1>
      <p class="text-muted-foreground">
        Isi laporan hasil pelaksanaan lembur.
      </p>
    </div>

    <div class="card p-6 max-w-3xl">

      <div class="mb-4">
        <label class="font-semibold">
          Nomor Request
        </label>
        <p><%= lembur.request_number %></p>
      </div>

      <div class="mb-6">
        <label class="font-semibold">
          Agenda Lembur
        </label>
        <p><%= lembur.title %></p>
      </div>

      <form action="/pegawai/laporan/<%= lembur.id %>" method="POST">

        <div class="mb-6">
          <label class="block mb-2 font-semibold">
            Hasil Pelaksanaan Lembur
          </label>

          <textarea
            name="laporan"
            rows="6"
            class="input w-full"
            required
          ><%= lembur.realization_notes || '' %></textarea>
        </div>

        <button
          type="submit"
          class="btn btn-primary"
        >
          Simpan Laporan
        </button>

      </form>

    </div>

  </main>

</body>
</html>
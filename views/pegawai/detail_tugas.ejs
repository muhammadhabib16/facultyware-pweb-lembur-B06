  <%- include('../partials/sidebar') %>

  <div class="p-6">
    <h1 class="text-2xl font-bold mb-6">
      Detail Penugasan Lembur
    </h1>

    <div class="card p-6 space-y-4">

      <div>
        <strong>Nomor Penugasan</strong>
        <p><%= tugas.request_number %></p>
      </div>

      <div>
        <strong>Agenda Lembur</strong>
        <p><%= tugas.title %></p>
      </div>

      <div>
        <strong>Pemberi Tugas</strong>
        <p><%= tugas.pimpinan_name || '-' %></p>
      </div>

      <div>
        <strong>Tanggal Penugasan</strong>
        <p>
          <%= new Date(tugas.request_date)
          .toLocaleDateString('id-ID') %>
        </p>
      </div>

      <div>
        <strong>Status Penugasan</strong>
        <p><%= tugas.status %></p>
      </div>

      <div>
        <strong>Deskripsi</strong>
        <p><%= tugas.description || '-' %></p>
      </div>

    </div>

    <div class="flex gap-3 mt-6">
        <a
          href="/pegawai/tugas/<%= tugas.id %>/export/pdf"
          hx-boost="false"
          class="btn btn-outline"
        >
          Export Detail PDF
        </a>
      
      <% if (tugas.status === 'assigned' || tugas.status === 'pending') { %>
        <a
          href="/pegawai/tugas/<%= tugas.id %>/lapor"
          class="btn btn-primary"
        >
          Isi Laporan
        </a>
      <% } %>

      <a
        href="/pegawai/tugas"
        class="btn btn-outline"
      >
        ← Kembali ke Daftar Penugasan
      </a>
    </div>

  </div>
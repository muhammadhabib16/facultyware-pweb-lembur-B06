<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body class="bg-background flex min-h-screen text-foreground">

    <%- include('../partials/sidebar') %>

    <main class="flex-1 p-4 md:p-6 space-y-5 max-w-6xl mx-auto w-full" hx-boost="true">
      <%-- Header & Actions --%>
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
        <div class="flex items-start gap-4">
          <a href="/pegawai/tugas" class="btn btn-sm btn-outline cursor-pointer mt-1">← Kembali</a>
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-2xl font-bold tracking-tight"><%= tugas.request_number %></h1>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize border
                <%= tugas.status === 'draft' ? 'bg-slate-500/10 text-slate-600 border-slate-500/20' : '' %>
                <%= tugas.status === 'pending' ? 'bg-amber-500/10 text-amber-600 border-amber-500/20' : '' %>
                <%= tugas.status === 'approved' ? 'bg-blue-500/10 text-blue-600 border-blue-500/20' : '' %>
                <%= tugas.status === 'rejected' ? 'bg-rose-500/10 text-rose-600 border-rose-500/20' : '' %>
                <%= tugas.status === 'completed' ? 'bg-emerald-500/10 text-emerald-600 border-emerald-500/20' : '' %>
                <%= tugas.status === 'cancelled' ? 'bg-red-500/10 text-red-600 border-red-500/20' : '' %>
              ">
                <%= tugas.status %>
              </span>
            </div>
            <p class="text-xs text-muted-foreground mt-1">Detail agenda penugasan lembur.</p>
          </div>
        </div>

        <div class="flex gap-2 flex-shrink-0">
          <% if (tugas.status === 'pending') { %>
            <%-- Hanya permohonan mandiri (pending) yang bisa dibatalkan --%>
            <button
              hx-post="/pegawai/permohonan/<%= tugas.id %>/batal"
              hx-confirm="Yakin ingin membatalkan pengajuan lembur mandiri ini? Data akan dihapus permanen."
              class="btn btn-sm btn-outline border-destructive text-destructive hover:bg-destructive/10 cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              Batalkan Pengajuan
            </button>
          <% } %>
          <% if (tugas.status === 'assigned' || tugas.status === 'pending') { %>
            <a href="/pegawai/tugas/<%= tugas.id %>/lapor" class="btn btn-sm btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg>
              Isi Laporan Pelaksanaan
            </a>
          <% } %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <%-- Info Utama --%>
        <div class="rounded-xl border bg-card p-6 md:col-span-2 space-y-6 shadow-sm">
          <div>
            <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Judul Agenda Kerja</h3>
            <p class="text-lg font-bold mt-1 text-foreground"><%= tugas.title %></p>
          </div>
          <hr />
          <div>
            <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Deskripsi Tugas / Agenda</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mt-1 bg-muted/40 p-4 rounded-lg border border-dashed">
              <%= tugas.description || 'Tidak ada deskripsi tambahan.' %>
            </p>
          </div>
          <hr />
          <div>
            <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-3">Daftar Anggota Lembur</h3>
            <div class="overflow-x-auto border rounded-lg">
              <table class="table w-full text-left border-collapse text-xs">
                <thead class="bg-muted/50 font-semibold text-muted-foreground border-b">
                  <tr>
                    <th class="p-3">Nama Anggota</th>
                    <th class="p-3">NIP / No. Pegawai</th>
                    <th class="p-3">Peran</th>
                    <th class="p-3">Rencana Jam</th>
                  </tr>
                </thead>
                <tbody class="divide-y">
                  <% if (typeof members !== 'undefined' && members && members.length > 0) { %>
                    <% members.forEach(member => { %>
                      <tr class="hover:bg-muted/10">
                        <td class="p-3 font-medium text-foreground"><%= member.employee_name %></td>
                        <td class="p-3 text-muted-foreground"><%= member.employee_number %></td>
                        <td class="p-3 capitalize"><%= member.role || 'Anggota' %></td>
                        <td class="p-3 font-mono text-primary"><%= member.planned_hours %> jam</td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="4" class="p-4 text-center text-muted-foreground">Tidak ada anggota terdaftar.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <%-- Sidebar Info --%>
        <div class="rounded-xl border bg-card p-6 space-y-4 text-sm shadow-sm">
          <h2 class="font-bold border-b pb-2">Info Pelaksanaan</h2>
          <div>
            <span class="text-muted-foreground block text-xs">Tanggal Pelaksanaan:</span>
            <span class="font-semibold block">
              <%= new Date(tugas.request_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %>
            </span>
          </div>
          <div>
            <span class="text-muted-foreground block text-xs">Rencana Jam Kerja:</span>
            <span class="font-semibold text-xs block font-mono text-indigo-500">
              <%= new Date(tugas.planned_start_time).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %>
              s/d
              <%= new Date(tugas.planned_end_time).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %>
            </span>
          </div>
          <hr />
          <div>
            <span class="text-muted-foreground block text-xs">Nama Pimpinan:</span>
            <span class="font-semibold text-xs bg-blue-500/10 text-blue-600 px-2 py-0.5 rounded-full mt-1 inline-block">
              👤 <%= tugas.pimpinan_name || 'Tidak Ada' %>
            </span>
          </div>
          <div class="mt-2 pt-2 border-t">
            <p class="text-xs text-amber-600 bg-amber-50 dark:bg-amber-500/10 p-2 rounded-lg border border-amber-200 dark:border-amber-500/20">
              ⚠️ Setelah lembur selesai, segera isi laporan pelaksanaan untuk dikirim ke pimpinan.
            </p>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>

<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>

  <body class="bg-background flex min-h-screen text-foreground">
    <%- include('../partials/sidebar') %>

    <main class="flex-1 p-4 md:p-6 space-y-5 max-w-4xl mx-auto w-full" hx-boost="true">
      <div>
        <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
        <p class="text-sm text-muted-foreground">
          Isi laporan pelaksanaan lembur setelah tugas selesai dikerjakan.
        </p>
      </div>

      <div class="card p-6 border rounded-lg bg-background space-y-5">
        <div>
          <h2 class="text-lg font-semibold">Detail Penugasan</h2>
          <div class="mt-4 space-y-3 text-sm">
            <div>
              <p class="font-semibold">Nomor Penugasan</p>
              <p><%= tugas.request_number %></p>
            </div>

            <div>
              <p class="font-semibold">Agenda Lembur</p>
              <p><%= tugas.title %></p>
            </div>

            <div>
              <p class="font-semibold">Status</p>
              <p>
                <% if (tugas.status === 'assigned') { %>
                  Assigned
                <% } else if (tugas.status === 'pending') { %>
                  Pending
                <% } else if (tugas.status === 'waiting_approval') { %>
                  Waiting Approval
                <% } else if (tugas.status === 'approved') { %>
                  Approved
                <% } else if (tugas.status === 'rejected') { %>
                  Rejected
                <% } else if (tugas.status === 'cancelled') { %>
                  Cancelled
                <% } else { %>
                  <%= tugas.status || '-' %>
                <% } %>
              </p>
            </div>
          </div>
        </div>

        <% if (error) { %>
          <div class="bg-red-500/15 text-red-500 text-sm p-4 rounded-md border border-red-500/20">
            <%= error %>
          </div>
        <% } %>

        <form
          action="/pegawai/tugas/<%= tugas.id %>/lapor"
          method="POST"
          class="space-y-4"
        >
          <div class="space-y-2">
            <label class="text-sm font-medium">Waktu Mulai Aktual</label>
            <input
              type="datetime-local"
              name="actual_start_time"
              class="input w-full"
              required
            />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">Waktu Selesai Aktual</label>
            <input
              type="datetime-local"
              name="actual_end_time"
              class="input w-full"
              required
            />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium">Catatan Hasil Pekerjaan</label>
            <textarea
              name="notes"
              rows="5"
              class="input w-full"
              placeholder="Tuliskan hasil pekerjaan lembur..."
              required
            ></textarea>
          </div>

          <div class="flex gap-3 pt-2">
            <button type="submit" class="btn btn-primary">
              Submit Report
            </button>

            <a href="/pegawai/tugas/<%= tugas.id %>" class="btn btn-outline">
              Cancel
            </a>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>